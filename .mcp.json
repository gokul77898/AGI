      "args": ["-y", "mcp-server-apple-shortcuts"]
    },
    "cli": {
      "command": "uvx",
      "args": ["cli-mcp-server"]
    },
    "calculator": {
      "command": "npx",
      "args": ["-y", "@wrtnlabs/calculator-mcp"]
    },
    "screenshot": {
      "command": "uvx",
      "args": ["mcp-screenshot"]
    },

    "rss": {
      "command": "uvx",
      "args": ["mcp-rss"]
    },
    "html-to-markdown": {
