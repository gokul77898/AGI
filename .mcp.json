    },
    "redis": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-redis", "redis://localhost:6379"]
    },
    "duckdb": {
      "command": "uvx",
      "args": ["mcp-server-motherduck"]
    },
    "chroma": {
      "command": "uvx",
      "args": ["chroma-mcp"]
    },
    "qdrant": {
      "command": "uvx",
      "args": ["mcp-server-qdrant"]
    },

    "applescript": {
