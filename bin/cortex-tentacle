#!/usr/bin/env node
/**
 * CORTEX Tentacle CLI — multi-agent orchestration via scoped context folders.
 *
 * Usage:
 *   cortex-tentacle new <name> [--context "..."] [--parent <id>] [--todo "item" ...]
 *   cortex-tentacle list
 *   cortex-tentacle remove <id>
 *   cortex-tentacle todo <id>                     # show todos
 *   cortex-tentacle todo <id> add "buy milk"      # add a todo
 *   cortex-tentacle todo <id> check <index>       # mark todo done
 *   cortex-tentacle msg <from> <to> "text"        # send inter-agent message
 *   cortex-tentacle inbox <id>                    # read incoming messages
 *   cortex-tentacle spawn <id> "task description" # launch child CORTEX agent
 *   cortex-tentacle show <id>                     # dump full tentacle state
 */

import { dirname, resolve, join } from 'node:path'
import { fileURLToPath } from 'node:url'
import { existsSync, readFileSync } from 'node:fs'

const __dirname = dirname(fileURLToPath(import.meta.url))
const managerPath = resolve(__dirname, '../src/tentacles/manager.mjs')

const mgr = await import(managerPath)

const argv = process.argv.slice(2)
const cmd = argv[0]

function usage() {
  console.log(`CORTEX Tentacles — multi-agent orchestration

Usage:
  cortex-tentacle new <name> [--context "..."] [--parent <id>] [--todo "..."]
  cortex-tentacle list
  cortex-tentacle remove <id>
  cortex-tentacle show <id>
  cortex-tentacle todo <id>
  cortex-tentacle todo <id> add "<text>"
  cortex-tentacle todo <id> check <index>
  cortex-tentacle msg <from-id> <to-id> "<text>"
  cortex-tentacle inbox <id>
  cortex-tentacle spawn <id> "<prompt>"

Tentacles live under .cortex/tentacles/<id>/
`)
}

function parseArgs(args) {
  const out = { _: [] }
  for (let i = 0; i < args.length; i++) {
    const a = args[i]
    if (a === '--context') { out.context = args[++i] }
    else if (a === '--parent') { out.parent = args[++i] }
    else if (a === '--todo') { (out.todos ??= []).push(args[++i]) }
    else { out._.push(a) }
  }
  return out
}

try {
  switch (cmd) {
    case 'new':
    case 'create': {
      const { _: positional, context, parent, todos } = parseArgs(argv.slice(1))
      const name = positional[0]
      if (!name) { console.error('error: name required'); process.exit(1) }
      const r = mgr.createTentacle({ name, context, parent, todos })
      console.log(`✓ Created tentacle '${r.id}' at ${r.dir}`)
      break
    }

    case 'list':
    case 'ls': {
      const tentacles = mgr.listTentacles()
      if (!tentacles.length) { console.log('(no tentacles — create one with: cortex-tentacle new <name>)'); break }
      console.log('ID'.padEnd(24), 'STATUS'.padEnd(10), 'TODOS'.padEnd(12), 'PARENT'.padEnd(16), 'CHILDREN')
      console.log('─'.repeat(80))
      for (const t of tentacles) {
        console.log(
          (t.id || '?').padEnd(24),
          (t.status || '?').padEnd(10),
          `${t.todos.done}/${t.todos.total}`.padEnd(12),
          (t.parent || '—').padEnd(16),
          (t.children || []).join(',') || '—',
        )
      }
      break
    }

    case 'remove':
    case 'rm': {
      const id = argv[1]
      if (!id) { console.error('error: id required'); process.exit(1) }
      mgr.removeTentacle(id)
      console.log(`✓ Removed tentacle '${id}'`)
      break
    }

    case 'show': {
      const id = argv[1]
      if (!id) { console.error('error: id required'); process.exit(1) }
      const dir = join(mgr.TENTACLE_ROOT, id)
      if (!existsSync(dir)) { console.error(`tentacle '${id}' not found`); process.exit(1) }
      console.log(`Tentacle: ${id}`)
      console.log(`Path: ${dir}`)
      console.log('\n--- CONTEXT.md ---')
      console.log(readFileSync(join(dir, 'CONTEXT.md'), 'utf8'))
      console.log('\n--- todo.md ---')
      console.log(readFileSync(join(dir, 'todo.md'), 'utf8'))
      const inbox = mgr.readInbox(id)
      console.log(`\n--- inbox (${inbox.length} messages) ---`)
      for (const m of inbox) console.log(`[${m.timestamp}] ${m.from} → ${m.to}: ${m.text}`)
      break
    }

    case 'todo': {
      const id = argv[1]
      const action = argv[2]
      if (!id) { console.error('error: id required'); process.exit(1) }

      if (!action) {
        const { items } = mgr.readTodos(id)
        if (!items.length) { console.log('(empty)'); break }
        items.forEach((it, i) => console.log(`  ${i}. [${it.done ? 'x' : ' '}] ${it.text}`))
        break
      }

      if (action === 'add') {
        const text = argv.slice(3).join(' ')
        if (!text) { console.error('error: text required'); process.exit(1) }
        mgr.addTodo(id, text)
        console.log(`✓ Added: ${text}`)
      } else if (action === 'check' || action === 'done') {
        const idx = parseInt(argv[3], 10)
        if (isNaN(idx)) { console.error('error: numeric index required'); process.exit(1) }
        const r = mgr.checkTodo(id, idx)
        console.log(`✓ Checked: ${r.checked}`)
      } else {
        console.error(`unknown todo action: ${action}`); process.exit(1)
      }
      break
    }

    case 'msg':
    case 'message': {
      const [from, to, ...rest] = argv.slice(1)
      const text = rest.join(' ')
      if (!from || !to || !text) { console.error('usage: cortex-tentacle msg <from> <to> "<text>"'); process.exit(1) }
      const m = mgr.sendMessage(from, to, text)
      console.log(`✓ Sent ${m.id} from ${from} → ${to}`)
      break
    }

    case 'inbox': {
      const id = argv[1]
      if (!id) { console.error('error: id required'); process.exit(1) }
      const msgs = mgr.readInbox(id)
      if (!msgs.length) { console.log('(empty)'); break }
      for (const m of msgs) console.log(`[${m.timestamp}] ${m.from}: ${m.text}`)
      break
    }

    case 'spawn': {
      const id = argv[1]
      const prompt = argv.slice(2).join(' ')
      if (!id) { console.error('error: id required'); process.exit(1) }
      const r = mgr.spawnAgent(id, { prompt })
      console.log(`✓ Spawned agent for '${id}' (pid ${r.pid})`)
      break
    }

    case undefined:
    case 'help':
    case '-h':
    case '--help':
      usage()
      break

    default:
      console.error(`unknown command: ${cmd}`)
      usage()
      process.exit(1)
  }
} catch (err) {
  console.error(`error: ${err.message}`)
  process.exit(1)
}
